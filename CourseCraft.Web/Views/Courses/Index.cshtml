@{
    ViewData[index: "Title"] = "Courses";
}
@model CourseCraft.Repository.ViewModels.CourseViewModel
<div class="d-flex flex-column w-100 p-4">
    <div class="d-flex justify-content-between w-100 mb-3 d-sm-row d-column flex-wrap flex-sm-nowrap">
        <h1 class="custom-body-text-color">Courses</h1>
        <div class="d-flex align-items-center gap-2 d-sm-row d-column  flex-wrap flex-sm-nowrap">
            <div class="d-flex align-items-center border rounded px-2 bg-white"
                 style="gap: 5px; width: 220px; height: 38px;">
                <input class="form-control border-0 shadow-none p-0" type="text" placeholder="Search" id="searchInput"
                       style="width: 100%; font-size: 14px; height: 100%;">
                <i class="bi bi-search"></i>
            </div>

            <a class="btn btn-primary text-white d-flex align-items-center" style="height: 38px; padding: 6px 12px;"
                   id="openAddCourseModal">
                + New Course
            </a>

        </div>
    </div>
    <div id="courseContainer">
    </div>
</div>
<!-- Add New Course Modal -->
<div class="modal fade" id="addCourseModal" tabindex="-1" aria-labelledby="addCourseModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addCourseModalLabel">Add New Course</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="addCourseForm" asp-action="AddNewCourse" asp-controller="Courses" method="post">
                    <div class="mb-3">
                        <div class="form-floating">
                            <input asp-for="CourseName" class="form-control" placeholder="Name" />
                            <span asp-validation-for="CourseName" class="text-danger"></span>
                            <label asp-for="CourseName" class="form-label">Course Name*</label>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <div class="form-floating">
                                <input asp-for="CourseDepartment" class="form-control" placeholder="CourseDepartment" />
                                <span asp-validation-for="CourseDepartment" class="text-danger"></span>
                                <label asp-for="CourseDepartment" class="form-label">Course Department*</label>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="form-floating">
                                <input asp-for="CourseCredits" class="form-control" placeholder="Course Credits*" />
                                <span asp-validation-for="CourseCredits" class="text-danger"></span>
                                <label asp-for="CourseCredits" class="form-label">Course Credits*</label>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="form-floating">
                            <input asp-for="CourseContent" class="form-control" placeholder="CourseContent" />
                            <span asp-validation-for="CourseContent" class="text-danger"></span>
                            <label asp-for="CourseContent" class="form-label">Course Content*</label>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer d-flex justify-content-end">
                <button type="submit" class="btn btn-primary text-white" form="addCourseForm">Save</button>
                <button type="button" class="btn btn-outline-primary" data-bs-dismiss="modal">Cancel</button>
            </div>
        </div>
    </div>
</div>

<!-- Edit  Course Modal -->
<div class="modal fade" id="editCourseModal" tabindex="-1" aria-labelledby="editCourseModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editCourseModal">Add New Course</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="editCourseForm" asp-action="UpdateCourse" asp-controller="Courses" method="post">
                    <input type="hidden" id="editCourseId" name="CourseId" />
                    <div class="mb-3">
                        <div class="form-floating">
                            <input asp-for="CourseName" class="form-control" placeholder="Name" id="editCourseName" />
                            <span asp-validation-for="CourseName" class="text-danger"></span>
                            <label asp-for="CourseName" class="form-label">Course Name*</label>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <div class="form-floating">
                                <input asp-for="CourseDepartment" class="form-control" placeholder="CourseDepartment"
                                       id="editCourseDepartment" />
                                <span asp-validation-for="CourseDepartment" class="text-danger"></span>
                                <label asp-for="CourseDepartment" class="form-label">Course Department*</label>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="form-floating">
                                <input asp-for="CourseCredits" class="form-control" placeholder="Course Credits*"
                                       id="editCourseCredits" />
                                <span asp-validation-for="CourseCredits" class="text-danger"></span>
                                <label asp-for="CourseCredits" class="form-label">Course Credits*</label>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="form-floating">
                            <input asp-for="CourseContent" class="form-control" placeholder="CourseContent"
                                   id="editCourseContent" />
                            <span asp-validation-for="CourseContent" class="text-danger"></span>
                            <label asp-for="CourseContent" class="form-label">Course Content*</label>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer d-flex justify-content-end">
                <button type="submit" class="btn btn-primary text-white" form="editCourseForm"
                        id="saveChangesBtn">Save</button>
                <button type="button" class="btn btn-outline-primary" data-bs-dismiss="modal">Cancel</button>
            </div>
        </div>
    </div>
</div>
<!-- Delete Tax Modal -->
<div class="modal fade" id="deleteCourseModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5">Delete Confirmation</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="deleteCourseForm">
                <div class="modal-body text-center">
                    <i class="bi bi-exclamation-triangle" width="30px" height="30px" class="mb-2"></i>
                    <p>Are you sure you want to delete this course?</p>
                    <input type="hidden" id="deleteCourseId">
                </div>
                <div class="modal-footer d-flex justify-content-center">
                    <button type="submit" class="btn btn-primary text-white">YES</button>
                    <button type="button" class="btn btn-outline-primary" data-bs-dismiss="modal">NO</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/course.js"></script>
}